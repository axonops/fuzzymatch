# fuzzymatch — generated artefacts excluded from version control.
#
# bench.txt IS committed (the benchstat baseline — see CLAUDE.md "Releases"
# and plan 01-04). bench.txt.new is a transient produced by `make bench` and
# is excluded here.

# Go build/test artefacts
coverage.out
coverage.html
bench.txt.new
*.test
*.prof
*.out.tmp

# Example program binaries produced by `go build` from the examples/
# subdirectories. The binary name matches the directory name (e.g.
# examples/scorer-composition/scorer-composition).
examples/identifier-similarity/identifier-similarity
examples/scorer-composition/scorer-composition

# Editor / OS noise
.DS_Store
*.swp
*~

# Local dev caches
.idea/
.vscode/

# Python bytecode caches (scripts/gen-swg-cross-validation.py and any future
# developer-discretion Python helpers under scripts/)
__pycache__/
*.pyc
*.pyo
